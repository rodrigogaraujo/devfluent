# Telegram Bot
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_WEBHOOK_URL=https://your-domain.railway.app

# AI Services
OPENAI_API_KEY=sk-your-openai-api-key
GROQ_API_KEY=gsk_your-groq-api-key

# Database
DATABASE_URL=postgresql+asyncpg://devfluent:devfluent@localhost:15432/devfluent

# Redis (Upstash)
REDIS_URL=redis://localhost:16379

# Cloudflare R2 (optional — system works without it)
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=devfluent-audio
R2_PUBLIC_URL=

# Monitoring (optional)
SENTRY_DSN=
POSTHOG_API_KEY=

# Admin
ADMIN_TELEGRAM_ID=

# Tuning
MAX_CONTEXT_TOKENS=4000
CONVERSATION_TIMEOUT_MIN=30
MAX_MESSAGES_PER_DAY=100
TTS_SPEED=1.0
